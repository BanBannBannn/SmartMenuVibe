# =============================================================================
# SmartMenu - Bien moi truong (muc 12.2)
# Copy file nay thanh .env.local va dien gia tri that. KHONG commit .env.local.
# =============================================================================

# --- Supabase ---------------------------------------------------------------
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# server-only, KHONG expose ra client. Bypass toan bo RLS => tuyet doi khong import vao client component.
SUPABASE_SERVICE_ROLE_KEY=
# Supavisor Session pooler (port 5432, ho tro IPv4 moi goi) - dung cho migration/script admin (muc 7.1)
# vd: postgresql://postgres.<ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
SUPABASE_DB_POOLER_URL=

# --- Azure Face API ---------------------------------------------------------
# Project: smartmenu.cognitiveservices.azure.com
AZURE_FACE_KEY=
AZURE_FACE_ENDPOINT=
# Bat = true CHI SAU KHI Microsoft duyet Face Identify (muc 7.2). Mac dinh false.
FACE_IDENTIFY_ENABLED=false
# Ten PersonGroup dung cho Identify (chi co tac dung khi FACE_IDENTIFY_ENABLED=true)
AZURE_FACE_PERSON_GROUP=smartmenu-guests

# --- OpenWeatherMap ---------------------------------------------------------
# Endpoint Current Weather Data 2.5 (mien phi, khong can the) - muc 7.3
OPENWEATHER_API_KEY=

# --- LLM (AI viet mo ta mon / goi y theme - muc 3.4) ------------------------
# Tuy chon. Neu de trong, tinh nang AI se tu dong fallback (mo ta nhap tay + theme chon san).
# Ho tro Anthropic hoac OpenAI - dien 1 trong 2.
LLM_PROVIDER=                       # 'anthropic' | 'openai' | rong = tat
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=                          # vd: claude-3-5-sonnet-latest hoac gpt-4o-mini

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
# Bat/tat cong thanh toan online (Phase 3). Mac dinh tat (thanh toan tai quay).
NEXT_PUBLIC_PAYMENTS_ENABLED=false
# Ngon ngu mac dinh giao dien
NEXT_PUBLIC_DEFAULT_LOCALE=vi
